import { getEntry, render } from "astro:content";
import Markdown from "@components/misc/Markdown.astro";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import FriendLinkCard from "@components/misc/FriendLinkCard.astro";
import { friendLinks } from "../config/links";
import { Icon } from "astro-icon/components";

const linksPost = await getEntry("spec", "links");

if (!linksPost) {
  throw new Error("Links page content not found");
}

const { Content } = await render(linksPost);

// 节点配置
const nodes = [
  { 
    name: "Cloudflare", 
    url: "https://blog.thelittlequtegdh.fun", 
    icon: "simple-icons:cloudflare", 
    description: "全球最大CDN，速度稳定" 
  },
  { 
    name: "EdgeOne", 
    url: "https://edgeone.thelittlequtegdh.fun", 
    icon: "simple-icons:tencent", 
    description: "腾讯云边缘节点，国内访问快" 
  },
  { 
    name: "Netlify", 
    url: "https://netlify.thelittlequtegdh.fun", 
    icon: "simple-icons:netlify", 
    description: "静态网站托管平台" 
  },
  { 
    name: "Vercel", 
    url: "https://vercel.thelittlequtegdh.fun", 
    icon: "simple-icons:vercel", 
    description: "前端开发者首选平台" 
  }
];

const currentHost = Astro.url.hostname;
---

<MainGridLayout title="友链" description="友情链接与节点状态">
    <!-- 友链卡片区域 -->
    {friendLinks.length > 0 && (
        <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32 mb-6">
            <div class="card-base z-10 px-9 py-6 relative w-full">
                <div class="flex items-center gap-3 mb-6">
                    <Icon name="material-symbols:group-rounded" class="text-3xl text-[var(--primary)]" />
                    <h2 class="text-2xl font-bold text-[var(--primary)]">友链列表</h2>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    {friendLinks.map((link) => (
                        <FriendLinkCard
                            name={link.name}
                            url={link.url}
                            description={link.description}
                            avatar={link.avatar}
                        />
                    ))}
                </div>
            </div>
        </div>
    )}

    <!-- 节点卡片区域 - 和友链完全一样的样式 -->
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32 mb-6">
        <div class="card-base z-10 px-9 py-6 relative w-full">
            <div class="flex items-center gap-3 mb-6">
                <Icon name="material-symbols:network-node-rounded" class="text-3xl text-[var(--primary)]" />
                <h2 class="text-2xl font-bold text-[var(--primary)]">节点列表</h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                {nodes.map((node) => {
                    const nodeHost = new URL(node.url).hostname;
                    const isCurrent = nodeHost === currentHost;
                    
                    return (
                        <a
                            href={node.url}
                            class:list={[
                                "flex items-center gap-3 p-4 rounded-[var(--radius)] transition-all duration-300",
                                "hover:bg-gray-100 dark:hover:bg-gray-800",
                                isCurrent && "border-2 border-[var(--primary)] bg-[var(--primary)]/5"
                            ]}
                            rel="noopener noreferrer"
                        >
                            <Icon name={node.icon} class="text-2xl" />
                            <div class="flex-1 min-w-0">
                                <div class="font-semibold truncate">{node.name}</div>
                                <div class="text-sm text-gray-500 dark:text-gray-400 truncate">{node.description}</div>
                            </div>
                            {isCurrent && (
                                <span class="text-xs bg-[var(--primary)] text-white px-2 py-0.5 rounded-full">当前</span>
                            )}
                        </a>
                    );
                })}
            </div>
        </div>
    </div>

    <!-- 说明文字区域 -->
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
        <div class="card-base z-10 px-9 py-6 relative w-full">
            <Markdown class="mt-2">
                <Content />
            </Markdown>
        </div>
    </div>
</MainGridLayout>
