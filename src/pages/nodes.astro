---
import Layout from '../layouts/Layout.astro'

const currentNode = import.meta.env.SITE_NODE_NAME || '未知节点'

const nodes = [
  {
    name: 'Cloudflare Pages',
    url: 'https://blog.thelittlequtegdh.fun',
    envName: 'Cloudflare Pages'
  },
  {
    name: 'Edgeone Pages',
    url: 'https://edgeone.thelittlequtegdh.fun',
    envName: 'EdgeonePages'
  },
  {
    name: 'Netlify',
    url: 'https://netlify.thelittlequtegdh.fun',
    envName: 'Netlify'
  },
  {
    name: 'Vercel',
    url: 'https://vercel.thelittlequtegdh.fun',
    envName: 'Vercel'
  }
]
---

<Layout title="节点监控" description="博客多节点实时延迟监控">
  <div class="max-w-3xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-2 text-center">节点监控</h1>
    <p class="text-center text-gray-500 dark:text-gray-400 mb-8">
      当前节点: <span class="font-semibold text-primary">{currentNode}</span>
    </p>

    <div class="grid gap-4 md:grid-cols-2">
      {nodes.map((node) => (
        <div 
          class="node-card bg-white dark:bg-gray-800 rounded-xl p-5 shadow-sm border border-gray-100 dark:border-gray-700 transition-all duration-300 hover:shadow-md"
          data-url={node.url}
          data-name={node.name}
          data-env={node.envName}
        >
          <div class="flex justify-between items-center mb-3">
            <h3 class="text-lg font-semibold flex items-center">
              <span class="w-2 h-2 rounded-full mr-2 bg-gray-300 status-indicator"></span>
              {node.name}
              {node.envName === currentNode && (
                <span class="ml-2 text-xs bg-primary/10 text-primary px-2 py-0.5 rounded-full">当前</span>
              )}
            </h3>
            <span class="latency text-gray-400 font-mono">-- ms</span>
          </div>
          
          <a 
            href={node.url} 
            target="_blank" 
            rel="noopener noreferrer"
            class="text-sm text-gray-500 dark:text-gray-400 hover:text-primary transition-colors truncate block"
          >
            {node.url}
          </a>
        </div>
      ))}
    </div>

    <div class="mt-8 text-center text-sm text-gray-400 dark:text-gray-500">
      <p>每3秒自动刷新延迟 | 点击节点地址可直接跳转</p>
      <p class="mt-1">延迟仅供参考，实际访问速度可能因网络环境而异</p>
    </div>
  </div>

  <script is:inline>
    // 节点ping检测函数
    async function pingNode(url) {
      const startTime = performance.now()
      const controller = new AbortController()
      const timeoutId = setTimeout(() => controller.abort(), 5000) // 5秒超时

      try {
        // 使用favicon.ico进行轻量级请求，避免跨域问题
        await fetch(`${url}/favicon.ico?${Date.now()}`, {
          method: 'HEAD',
          signal: controller.signal,
          mode: 'no-cors' // 关键：使用no-cors模式避免跨域错误
        })
        const latency = Math.round(performance.now() - startTime)
        clearTimeout(timeoutId)
        return { success: true, latency }
      } catch (error) {
        clearTimeout(timeoutId)
        if (error.name === 'AbortError') {
          return { success: false, latency: null, error: '超时' }
        }
        return { success: false, latency: null, error: '无法访问' }
      }
    }

    // 更新单个节点状态
    async function updateNodeStatus(card) {
      const url = card.dataset.url
      const statusIndicator = card.querySelector('.status-indicator')
      const latencyElement = card.querySelector('.latency')

      const result = await pingNode(url)

      if (result.success) {
        latencyElement.textContent = `${result.latency} ms`
        
        // 根据延迟设置颜色
        if (result.latency < 100) {
          statusIndicator.className = 'w-2 h-2 rounded-full mr-2 bg-green-500 status-indicator'
          latencyElement.className = 'latency text-green-500 font-mono font-semibold'
        } else if (result.latency < 300) {
          statusIndicator.className = 'w-2 h-2 rounded-full mr-2 bg-yellow-500 status-indicator'
          latencyElement.className = 'latency text-yellow-500 font-mono font-semibold'
        } else {
          statusIndicator.className = 'w-2 h-2 rounded-full mr-2 bg-orange-500 status-indicator'
          latencyElement.className = 'latency text-orange-500 font-mono font-semibold'
        }
      } else {
        latencyElement.textContent = result.error
        statusIndicator.className = 'w-2 h-2 rounded-full mr-2 bg-red-500 status-indicator'
        latencyElement.className = 'latency text-red-500 font-mono font-semibold'
      }
    }

    // 更新所有节点
    async function updateAllNodes() {
      const cards = document.querySelectorAll('.node-card')
      // 并行执行所有ping请求
      await Promise.all(Array.from(cards).map(card => updateNodeStatus(card)))
    }

    // 页面加载完成后立即执行
    document.addEventListener('DOMContentLoaded', () => {
      updateAllNodes()
      // 每3秒自动更新
      setInterval(updateAllNodes, 3000)
    })
  </script>
</Layout>
