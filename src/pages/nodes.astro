---
import MainGridLayout from '../layouts/MainGridLayout.astro'
const currentNode = import.meta.env.SITE_NODE_NAME || ""

const nodes = [
  {
    name: "Cloudflare Pages",
    url: "https://blog.thelittlequtegdh.fun",
    tag: "Cloudflare Pages",
    icon: "☁️"
  },
  {
    name: "Edgeone Pages",
    url: "https://edgeone.thelittlequtegdh.fun",
    tag: "EdgeonePages",
    icon: "⚡"
  },
  {
    name: "Netlify",
    url: "https://netlify.thelittlequtegdh.fun",
    tag: "Netlify",
    icon: "🌐"
  },
  {
    name: "Vercel",
    url: "https://vercel.thelittlequtegdh.fun",
    tag: "A"
  }
]
---

<MainGridLayout title="节点监控" description="博客多节点实时延迟监控">
<div class="max-w-3xl mx-auto px-4 py-6">
  <h1 class="text-2xl font-bold text-center mb-2">🌐 节点监控</h1>
  <p class="text-center text-gray-500 dark:text-gray-400 mb-6">
    当前节点: <span class="text-blue-500 font-semibold">{currentNode || "未识别"}</span>
  </p>

  <div class="space-y-3">
    {nodes.map(node => (
    <a href={node.url} target="_blank" rel="noopener noreferrer"
       class="flex items-center gap-4 p-4 rounded-xl bg-sky-50 dark:bg-sky-900/20 hover:bg-sky-100 dark:hover:bg-sky-900/30 transition-colors">
      <div class="w-14 h-14 rounded-full bg-white dark:bg-gray-800 shadow flex items-center justify-center text-2xl flex-shrink-0">
        {node.icon}
      </div>
      <div class="flex-1 min-w-0">
        <div class="font-semibold truncate">
          {node.name}
          {node.tag === currentNode && <span class="ml-2 text-xs px-2 py-0.5 rounded bg-blue-500/10 text-blue-500">当前</span>}
        </div>
        <div class="text-sm text-gray-400 truncate">{node.url}</div>
      </div>
      <div class="latency text-sm font-mono text-gray-400 flex-shrink-0" data-url={node.url}>-- ms</div>
      <svg class="w-5 h-5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
      </svg>
    </a>
    ))}
  </div>

  <p class="text-center text-xs text-gray-400 mt-8">
    每3秒自动刷新延迟 · 点击卡片直接跳转
  </p>
</div>

<script is:inline>
// 修复版ping函数，解决图片加载问题
async function pingNode(url) {
  const startTime = performance.now()
  const timeout = 3000

  return new Promise((resolve) => {
    const controller = new AbortController()
    const timeoutId = setTimeout(() => {
      resolve({ success: false, error: "超时" })
    }, timeout)

    // 改用HEAD请求 + no-cors，同时捕获所有错误
    fetch(`${url}/?ping=${Date.now()}`, {
      method: 'HEAD',
      mode: 'no-cors',
      signal: controller.signal
    })
    .then(() => {
      clearTimeout(timeoutId)
      const latency = Math.round(performance.now() - startTime)
      resolve({ success: true, latency })
    })
    .catch(() => {
      clearTimeout(timeoutId)
      resolve({ success: false, error: "连接异常" })
    })
  })
}

async function updateLatency() {
  const elements = document.querySelectorAll('.latency')
  for (const el of elements) {
    const url = el.dataset.url
    const result = await pingNode(url)

    if (result.success) {
      el.textContent = `${result.latency} ms`
      if (result.latency < 120) {
        el.className = 'latency text-sm font-mono text-green-500 flex-shrink-0'
      } else if (result.latency < 300) {
        el.className = 'latency text-sm font-mono text-yellow-500 flex-shrink-0'
      } else {
        el.className = 'latency text-sm font-mono text-orange-500 flex-shrink-0'
      }
    } else {
      el.textContent = result.error
      el.className = 'latency text-sm font-mono text-red-500 flex-shrink-0'
    }
  }
}

// 页面加载后立即执行两次，解决首次加载问题
document.addEventListener('DOMContentLoaded', () => {
  updateLatency()
  setTimeout(updateLatency, 500)
  setInterval(updateLatency, 3000)
})
</script>
</MainGridLayout>
