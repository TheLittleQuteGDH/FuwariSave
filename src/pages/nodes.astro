---
import MainGridLayout from '../layouts/MainGridLayout.astro';

const nodes = [
  {
    name: "Cloudflare",
    url: "https://blog.thelittlequtegdh.fun",
    icon: "☁️",
    description: "Cloudflare Pages 全球CDN加速",
    location: "全球边缘节点"
  },
  {
    name: "EdgeOne",
    url: "https://edgeone.thelittlequtegdh.fun",
    icon: "🌐",
    description: "腾讯云EdgeOne 国内优化",
    location: "中国境内加速"
  },
  {
    name: "Netlify",
    url: "https://netlify.thelittlequtegdh.fun",
    icon: "🔷",
    description: "Netlify 静态托管平台",
    location: "美国东部"
  },
  {
    name: "Vercel",
    url: "https://vercel.thelittlequtegdh.fun",
    icon: "▲",
    description: "Vercel 前端开发首选",
    location: "美国东部"
  }
];
---

<MainGridLayout title="节点状态" description="博客各节点状态与延迟测试">
  <div class="max-w-4xl mx-auto px-4 py-8">
    <!-- 页面标题 -->
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold mb-4 text-gray-900 dark:text-white">节点状态</h1>
      <p class="text-gray-600 dark:text-gray-400">实时监控博客各节点的运行状态与网络延迟</p>
    </div>

    <!-- 当前节点提示 -->
    <div class="card p-4 mb-8 text-center" id="current-node-card">
      <span class="text-gray-600 dark:text-gray-400">当前访问节点：</span>
      <span class="font-semibold text-primary" id="current-node-name">加载中...</span>
    </div>

    <!-- 节点卡片网格 -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6" id="nodes-grid">
      {nodes.map((node) => (
        <div 
          class="card p-6 transition-all duration-300 hover:shadow-lg node-card"
          data-url={node.url}
          data-name={node.name}
        >
          <div class="flex items-start justify-between mb-4">
            <div class="flex items-center gap-3">
              <span class="text-3xl">{node.icon}</span>
              <div>
                <h3 class="text-xl font-bold text-gray-900 dark:text-white">{node.name}</h3>
                <p class="text-sm text-gray-500 dark:text-gray-400">{node.location}</p>
              </div>
            </div>
            <div class="text-right">
              <div class="text-2xl font-bold latency-value text-gray-400">--</div>
              <div class="text-xs text-gray-500 dark:text-gray-400">平均延迟</div>
            </div>
          </div>
          
          <p class="text-gray-600 dark:text-gray-300 mb-4">{node.description}</p>
          
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <div class="w-3 h-3 rounded-full bg-gray-400 status-indicator"></div>
              <span class="text-sm text-gray-500 dark:text-gray-400 status-text">检测中...</span>
            </div>
            <a 
              href={node.url}
              class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary/90 transition-colors text-sm font-medium"
            >
              切换节点
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- 说明信息 -->
    <div class="mt-12 card p-6">
      <h3 class="text-lg font-bold mb-3 text-gray-900 dark:text-white">💡 说明</h3>
      <ul class="space-y-2 text-gray-600 dark:text-gray-300">
        <li>• 延迟数据每30秒自动刷新一次</li>
        <li>• 绿色表示节点在线，红色表示节点离线</li>
        <li>• 点击"切换节点"按钮可跳转到对应节点</li>
        <li>• 当前访问的节点会以蓝色边框高亮显示</li>
        <li>• 单次检测超时时间：1秒</li>
      </ul>
    </div>
  </div>
</MainGridLayout>

<style is:global>
  .node-card.current-node {
    border: 2px solid var(--primary);
    box-shadow: 0 0 20px rgba(var(--primary-rgb), 0.2);
  }
  
  .status-indicator.online {
    background-color: #10b981;
    animation: pulse 2s infinite;
  }
  
  .status-indicator.offline {
    background-color: #ef4444;
  }
  
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }
  
  .latency-value.excellent { color: #10b981; }
  .latency-value.good { color: #f59e0b; }
  .latency-value.poor { color: #ef4444; }
</style>

<script>
  let updateInterval;
  let initialized = false;

  // 1秒极速ping测试
  function pingNode(url) {
    return new Promise((resolve) => {
      const start = performance.now();
      const img = new Image();
      
      // 改为1秒超时
      const timer = setTimeout(() => {
        resolve({ success: false, latency: 1000 });
      }, 1000);
      
      img.onload = img.onerror = () => {
        clearTimeout(timer);
        const latency = Math.round(performance.now() - start);
        resolve({ success: true, latency });
      };
      
      img.src = `${new URL(url).origin}/favicon.ico?${Math.random()}`;
    });
  }

  // 更新单个节点状态
  async function updateNodeStatus(card) {
    const url = card.dataset.url;
    const statusIndicator = card.querySelector('.status-indicator');
    const statusText = card.querySelector('.status-text');
    const latencyValue = card.querySelector('.latency-value');
    
    const result = await pingNode(url);
    
    if (result.success) {
      statusIndicator.classList.remove('offline');
      statusIndicator.classList.add('online');
      statusText.textContent = '在线';
      
      latencyValue.textContent = `${result.latency}ms`;
      latencyValue.classList.remove('excellent', 'good', 'poor');
      
      if (result.latency < 100) {
        latencyValue.classList.add('excellent');
      } else if (result.latency < 300) {
        latencyValue.classList.add('good');
      } else {
        latencyValue.classList.add('poor');
      }
    } else {
      statusIndicator.classList.remove('online');
      statusIndicator.classList.add('offline');
      statusText.textContent = '离线';
      latencyValue.textContent = '--';
      latencyValue.classList.remove('excellent', 'good', 'poor');
    }
  }

  // 初始化函数
  function initNodePage() {
    if (initialized) return;
    initialized = true;

    // 清除旧定时器
    if (updateInterval) {
      clearInterval(updateInterval);
    }

    const currentHost = window.location.hostname;
    const nodeCards = document.querySelectorAll('.node-card');
    const currentNodeName = document.getElementById('current-node-name');
    
    // 第一步：立即显示当前节点（无需等待ping）
    nodeCards.forEach(card => {
      const nodeHost = new URL(card.dataset.url).hostname;
      if (nodeHost === currentHost) {
        card.classList.add('current-node');
        currentNodeName.textContent = card.dataset.name;
      } else {
        card.classList.remove('current-node');
      }
    });

    // 第二步：立即开始ping检测
    (async () => {
      for (const card of nodeCards) {
        await updateNodeStatus(card);
      }
    })();

    // 第三步：设置30秒自动刷新
    updateInterval = setInterval(async () => {
      for (const card of nodeCards) {
        await updateNodeStatus(card);
      }
    }, 30000);
  }

  // 直接访问页面时执行
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initNodePage);
  } else {
    initNodePage();
  }

  // Swup无刷新跳转时执行（关键！解决导航栏点击不执行的问题）
  document.addEventListener('swup:contentReplaced', () => {
    initialized = false;
    initNodePage();
  });
</script>
