---
import MainGridLayout from '../layouts/MainGridLayout.astro'
const nowNode = import.meta.env.SITE_NODE_NAME || "未知节点"

const nodeList = [
  {
    name: "Cloudflare Pages",
    host: "https://blog.thelittlequtegdh.fun",
    tag: "Cloudflare Pages"
  },
  {
    name: "EdgeonePages",
    host: "https://edgeone.thelittlequtegdh.fun",
    tag: "EdgeonePages"
  },
  {
    name: "Netlify",
    host: "https://netlify.thelittlequtegdh.fun",
    tag: "Netlify"
  },
  {
    name: "Vercel",
    host: "https://vercel.thelittlequtegdh.fun",
    tag: "Vercel"
  }
]
---

<MainGridLayout title="节点状态" desc="多线路节点延迟监测">
<div class="py-6 px-2">
  <h2 class="text-center text-xl font-bold mb-2">多线路节点监测</h2>
  <p class="text-center text-sm text-gray-500 dark:text-gray-400 mb-6">
    当前运行节点：<strong class="text-primary">{nowNode || "未识别"}</strong>
  </p>

  <div class="flex flex-col gap-3">
    {nodeList.map(item => (
    <div class="border dark:border-gray-700 rounded-lg p-4 flex justify-between items-center bg-gray-50 dark:bg-gray-800">
      <div>
        <div class="font-medium">
          {item.name}
          {item.tag === nowNode && <span class="ml-2 text-xs px-2 py-0.5 rounded bg-primary/10 text-primary">当前</span>}
        </div>
        <div class="text-xs text-gray-400 mt-1">{item.host}</div>
      </div>
      <div class="speed-data text-sm font-mono" data-domain={item.host}>正在检测</div>
    </div>
    ))}
  </div>

  <p class="text-center text-xs text-gray-400 mt-6">自动3秒刷新延迟 · 打开页面立即测速</p>
</div>

<script>
function getLatency(domain) {
  return new Promise(resolve => {
    let start = performance.now();
    let img = new Image();
    let timer = setTimeout(()=>resolve("超时"),3000);
    img.src = domain + "/favicon.ico?_t="+Date.now();
    img.onload = ()=>{
      clearTimeout(timer);
      let t = Math.round(performance.now()-start);
      resolve(t+"ms");
    }
    img.onerror = ()=>{
      clearTimeout(timer);
      resolve("连接异常");
    }
  })
}

async function checkAll(){
  let els = document.querySelectorAll(".speed-data");
  for(let el of els){
    let url = el.dataset.domain;
    let res = await getLatency(url);
    el.innerText = res;
    if(res.includes("ms")){
      let num = parseInt(res);
      if(num<120) el.className="speed-data text-sm font-mono text-green-500";
      else if(num<300) el.className="speed-data text-sm font-mono text-yellow-500";
      else el.className="speed-data text-sm font-mono text-orange-500";
    }else{
      el.className="speed-data text-sm font-mono text-red-500";
    }
  }
}

window.addEventListener("DOMContentLoaded",()=>{
  checkAll();
  setInterval(checkAll,3000);
})
</script>
</MainGridLayout>
