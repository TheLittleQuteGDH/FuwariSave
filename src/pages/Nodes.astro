---
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { Icon } from "astro-icon/components";

const nodes = [
  { 
    name: "Cloudflare", 
    url: "https://blog.thelittlequtegdh.fun", 
    icon: "simple-icons:cloudflare", 
    description: "全球最大CDN，速度稳定" 
  },
  { 
    name: "EdgeOne", 
    url: "https://edgeone.thelittlequtegdh.fun", 
    icon: "simple-icons:tencent", 
    description: "腾讯云边缘节点，国内访问快" 
  },
  { 
    name: "Netlify", 
    url: "https://netlify.thelittlequtegdh.fun", 
    icon: "simple-icons:netlify", 
    description: "静态网站托管平台" 
  },
  { 
    name: "Vercel", 
    url: "https://vercel.thelittlequtegdh.fun", 
    icon: "simple-icons:vercel", 
    description: "前端开发者首选平台" 
  }
];

const currentHost = Astro.url.hostname;
---

<MainGridLayout title="节点状态" description="博客各节点实时状态与延迟检测">
    <!-- 节点卡片区域 -->
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32 mb-6">
        <div class="card-base z-10 px-9 py-6 relative w-full">
            <div class="flex items-center gap-3 mb-6">
                <Icon name="material-symbols:network-node-rounded" class="text-3xl text-[var(--primary)]" />
                <h2 class="text-2xl font-bold text-[var(--primary)]">节点列表</h2>
            </div>
            
            <div class="mb-4 text-center">
                <p class="text-gray-600 dark:text-gray-400">实时检测各节点延迟，选择最快的节点访问</p>
                <p class="mt-2 text-lg">
                    当前节点：<span id="current-node" class="font-semibold text-[var(--primary)]">
                        {nodes.find(n => new URL(n.url).hostname === currentHost)?.name || "未知"}
                    </span>
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                {nodes.map((node) => {
                    const nodeHost = new URL(node.url).hostname;
                    const isCurrent = nodeHost === currentHost;
                    
                    return (
                        <div 
                            class:list={[
                                "rounded-[var(--radius)] p-4 transition-all duration-300 hover:shadow-md",
                                isCurrent && "border-2 border-[var(--primary)] shadow-md"
                            ]}
                            data-node={node.name}
                            data-host={nodeHost}
                            data-url={node.url}
                        >
                            <div class="flex items-center justify-between mb-3">
                                <div class="flex items-center gap-3">
                                    <Icon name={node.icon} class="text-2xl" />
                                    <div>
                                        <h3 class="text-lg font-semibold">{node.name}</h3>
                                        <p class="text-sm text-gray-500 dark:text-gray-400">{node.description}</p>
                                    </div>
                                </div>
                                <div class="text-right">
                                    <div class="text-xl font-bold latency" data-host={nodeHost}>--</div>
                                    <div class="text-xs text-gray-500 dark:text-gray-400">平均延迟</div>
                                </div>
                            </div>
                            
                            <div class="flex items-center justify-between">
                                <div class="flex items-center gap-2">
                                    <span class="w-3 h-3 rounded-full status-indicator bg-gray-400" data-host={nodeHost}></span>
                                    <span class="text-sm status-text" data-host={nodeHost}>检测中...</span>
                                </div>
                                <a 
                                    href={node.url}
                                    class="px-3 py-1.5 bg-[var(--primary)] text-white rounded-lg hover:bg-[var(--primary-hover)] transition-colors text-sm inline-block"
                                    rel="noopener noreferrer"
                                >
                                    跳转
                                </a>
                            </div>
                        </div>
                    );
                })}
            </div>
        </div>
    </div>

    <!-- 说明文字区域 -->
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
        <div class="card-base z-10 px-9 py-6 relative w-full">
            <div class="text-center text-gray-500 dark:text-gray-400">
                <p>延迟每5秒自动更新一次</p>
                <p class="mt-2">
                    <span class="inline-block w-3 h-3 rounded-full bg-green-500 mr-1"></span> 正常
                    <span class="inline-block w-3 h-3 rounded-full bg-yellow-500 mx-2 ml-4 mr-1"></span> 较慢
                    <span class="inline-block w-3 h-3 rounded-full bg-red-500 mx-2 ml-4 mr-1"></span> 超时
                </p>
            </div>
        </div>
    </div>
</MainGridLayout>

<style>
  .latency-good { color: #10b981; }
  .latency-medium { color: #f59e0b; }
  .latency-bad { color: #ef4444; }
</style>

<script client:only>
  const pingResults = {};
  const pingCount = {};
  let intervalId = null;
  
  // 初始化结果对象
  document.querySelectorAll('[data-host]').forEach(el => {
    const host = el.dataset.host;
    if (!pingResults[host]) {
      pingResults[host] = [];
      pingCount[host] = 0;
    }
  });
  
  // 单个节点ping函数
  function pingNode(host) {
    return new Promise((resolve) => {
      const start = Date.now();
      const timeout = setTimeout(() => resolve(Infinity), 3000);
      
      const img = new Image();
      img.onload = () => {
        clearTimeout(timeout);
        resolve(Date.now() - start);
      };
      img.onerror = () => {
        clearTimeout(timeout);
        resolve(Date.now() - start);
      };
      
      img.src = `https://${host}/favicon.ico?${Date.now()}`;
    });
  }
  
  // 更新延迟显示
  function updateLatency(host, latency) {
    const latencyEl = document.querySelector(`.latency[data-host="${host}"]`);
    const indicator = document.querySelector(`.status-indicator[data-host="${host}"]`);
    const statusText = document.querySelector(`.status-text[data-host="${host}"]`);
    
    if (!latencyEl || !indicator || !statusText) return;
    
    if (latency === Infinity) {
      latencyEl.textContent = '超时';
      latencyEl.className = 'text-xl font-bold latency latency-bad';
      indicator.className = 'w-3 h-3 rounded-full status-indicator bg-red-500';
      statusText.textContent = '超时';
    } else {
      latencyEl.textContent = `${Math.round(latency)}ms`;
      
      if (latency < 100) {
        latencyEl.className = 'text-xl font-bold latency latency-good';
        indicator.className = 'w-3 h-3 rounded-full status-indicator bg-green-500';
        statusText.textContent = '正常';
      } else if (latency < 300) {
        latencyEl.className = 'text-xl font-bold latency latency-medium';
        indicator.className = 'w-3 h-3 rounded-full status-indicator bg-yellow-500';
        statusText.textContent = '较慢';
      } else {
        latencyEl.className = 'text-xl font-bold latency latency-bad';
        indicator.className = 'w-3 h-3 rounded-full status-indicator bg-red-500';
        statusText.textContent = '较慢';
      }
    }
  }
  
  // 检测所有节点
  async function pingAllNodes() {
    const hosts = Object.keys(pingResults);
    for (const host of hosts) {
      const latency = await pingNode(host);
      pingResults[host].push(latency);
      pingCount[host]++;
      
      // 只保留最近10次结果
      if (pingResults[host].length > 10) {
        pingResults[host].shift();
      }
      
      const avgLatency = pingResults[host].reduce((a, b) => a + b, 0) / pingResults[host].length;
      updateLatency(host, avgLatency);
    }
  }
  
  // 立即执行一次
  pingAllNodes();
  
  // 每5秒自动检测一次
  intervalId = setInterval(pingAllNodes, 5000);
  
  // 页面离开时清理资源
  window.addEventListener('beforeunload', () => {
    if (intervalId) clearInterval(intervalId);
  });
  
  // 监听swup页面离开事件
  document.addEventListener('swup:willReplaceContent', () => {
    if (intervalId) clearInterval(intervalId);
  });
</script>
