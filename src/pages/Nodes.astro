---
import Layout from "../layouts/Layout.astro";

const nodes = [
  { name: "Cloudflare", url: "https://blog.thelittlequtegdh.fun", icon: "☁️", description: "全球最大CDN，速度稳定" },
  { name: "EdgeOne", url: "https://edgeone.thelittlequtegdh.fun", icon: "🌐", description: "腾讯云边缘节点，国内访问快" },
  { name: "Netlify", url: "https://netlify.thelittlequtegdh.fun", icon: "🔷", description: "静态网站托管平台" },
  { name: "Vercel", url: "https://vercel.thelittlequtegdh.fun", icon: "▲", description: "前端开发者首选平台" }
];
---

<Layout title="节点状态" description="博客各节点实时状态与延迟检测">
  <div class="max-w-4xl mx-auto px-4 py-8">
    <div class="mb-8 text-center">
      <h1 class="text-3xl font-bold mb-2">节点状态</h1>
      <p class="text-gray-600 dark:text-gray-400">实时检测各节点延迟，选择最快的节点访问</p>
      <p class="mt-2 text-lg">
        当前节点：<span id="current-node" class="font-semibold text-primary"></span>
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      {nodes.map((node) => (
        <div 
          class="card p-6 transition-all duration-300 hover:shadow-lg node-card"
          data-node={node.name}
          data-url={node.url}
        >
          <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-3">
              <span class="text-2xl">{node.icon}</span>
              <div>
                <h3 class="text-xl font-semibold">{node.name}</h3>
                <p class="text-sm text-gray-500 dark:text-gray-400">{node.description}</p>
              </div>
            </div>
            <div class="text-right">
              <div class="text-2xl font-bold latency">--</div>
              <div class="text-xs text-gray-500 dark:text-gray-400">平均延迟</div>
            </div>
          </div>
          
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class="w-3 h-3 rounded-full status-indicator bg-gray-400"></span>
              <span class="text-sm status-text">检测中...</span>
            </div>
            <!-- 使用a标签而不是button，兼容swup转场 -->
            <a 
              href={node.url}
              class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary/90 transition-colors inline-block"
              data-swup-link
            >
              跳转
            </a>
          </div>
        </div>
      ))}
    </div>

    <div class="text-center text-gray-500 dark:text-gray-400">
      <p>延迟每5秒自动更新一次</p>
      <p class="mt-2">
        <span class="inline-block w-3 h-3 rounded-full bg-green-500 mr-1"></span> 正常
        <span class="inline-block w-3 h-3 rounded-full bg-yellow-500 mx-2 ml-4 mr-1"></span> 较慢
        <span class="inline-block w-3 h-3 rounded-full bg-red-500 mx-2 ml-4 mr-1"></span> 超时
      </p>
    </div>
  </div>
</Layout>

<!-- 移除所有is:global样式，避免污染全局 -->
<style>
  .node-current {
    border: 2px solid var(--primary) !important;
    box-shadow: 0 0 15px rgba(var(--primary-rgb), 0.3) !important;
  }
  
  .latency-good { color: #10b981; }
  .latency-medium { color: #f59e0b; }
  .latency-bad { color: #ef4444; }
</style>

<script>
  // 只在当前页面执行，避免影响其他页面
  if (window.location.pathname === '/nodes') {
    const pingResults = {};
    const pingCount = {};
    
    // 初始化结果对象
    document.querySelectorAll('.node-card').forEach(card => {
      const nodeName = card.dataset.node;
      pingResults[nodeName] = [];
      pingCount[nodeName] = 0;
    });
    
    // 显示当前节点
    const currentHost = window.location.hostname;
    document.querySelectorAll('.node-card').forEach(card => {
      const nodeUrl = new URL(card.dataset.url);
      if (nodeUrl.hostname === currentHost) {
        card.classList.add('node-current');
        document.getElementById('current-node').textContent = card.dataset.node;
      }
    });
    
    // 图片测速法（100%无跨域问题）
    function pingNode(card) {
      return new Promise((resolve) => {
        const nodeUrl = new URL(card.dataset.url);
        const host = nodeUrl.hostname;
        const nodeName = card.dataset.node;
        
        const img = new Image();
        const start = performance.now();
        const timeout = setTimeout(() => {
          resolve(Infinity);
        }, 5000);
        
        img.onload = img.onerror = () => {
          clearTimeout(timeout);
          const latency = Math.round(performance.now() - start);
          resolve(latency);
        };
        
        // 使用随机参数防止缓存
        img.src = `https://${host}/favicon.ico?${Math.random()}`;
      });
    }
    
    // 更新延迟显示
    function updateLatency(card, latency) {
      const latencyEl = card.querySelector('.latency');
      const indicator = card.querySelector('.status-indicator');
      const statusText = card.querySelector('.status-text');
      
      if (latency === Infinity) {
        latencyEl.textContent = '超时';
        latencyEl.className = 'text-2xl font-bold latency latency-bad';
        indicator.className = 'w-3 h-3 rounded-full status-indicator bg-red-500';
        statusText.textContent = '超时';
      } else {
        latencyEl.textContent = `${latency}ms`;
        
        if (latency < 100) {
          latencyEl.className = 'text-2xl font-bold latency latency-good';
          indicator.className = 'w-3 h-3 rounded-full status-indicator bg-green-500';
          statusText.textContent = '正常';
        } else if (latency < 300) {
          latencyEl.className = 'text-2xl font-bold latency latency-medium';
          indicator.className = 'w-3 h-3 rounded-full status-indicator bg-yellow-500';
          statusText.textContent = '较慢';
        } else {
          latencyEl.className = 'text-2xl font-bold latency latency-bad';
          indicator.className = 'w-3 h-3 rounded-full status-indicator bg-red-500';
          statusText.textContent = '较慢';
        }
      }
    }
    
    // 检测所有节点
    async function pingAllNodes() {
      const cards = document.querySelectorAll('.node-card');
      for (const card of cards) {
        const latency = await pingNode(card);
        const nodeName = card.dataset.node;
        
        // 更新结果
        pingResults[nodeName].push(latency);
        pingCount[nodeName]++;
        
        // 计算平均延迟
        const avgLatency = Math.round(
          pingResults[nodeName].reduce((a, b) => a + b, 0) / pingResults[nodeName].length
        );
        
        updateLatency(card, avgLatency);
      }
    }
    
    // 页面加载时立即检测一次
    pingAllNodes();
    
    // 每5秒自动检测一次
    const intervalId = setInterval(pingAllNodes, 5000);
    
    // 页面离开时清除定时器，避免内存泄漏
    window.addEventListener('beforeunload', () => {
      clearInterval(intervalId);
    });
  }
</script>
