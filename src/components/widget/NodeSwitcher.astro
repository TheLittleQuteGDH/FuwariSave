---
const nodes = [
  { name: "Cloudflare", url: "https://blog.thelittlequtegdh.fun", icon: "☁️" },
  { name: "EdgeOne", url: "https://edgeone.thelittlequtegdh.fun", icon: "🌐" },
  { name: "Netlify", url: "https://netlify.thelittlequtegdh.fun", icon: "🔷" },
  { name: "Vercel", url: "https://vercel.thelittlequtegdh.fun", icon: "▲" }
];

const currentHost = Astro.url.hostname;
---

<div class="card p-4">
  <div class="flex items-center gap-2 mb-3">
    <div class="w-1.5 h-6 bg-primary rounded-full"></div>
    <span class="font-semibold text-xl text-gray-900 dark:text-white">节点</span>
  </div>
  
  <div class="flex flex-col gap-2">
    {nodes.map((node) => {
      const nodeHost = new URL(node.url).hostname;
      const isActive = nodeHost === currentHost;
      
      return (
        <button 
          type="button"
          class:list={[
            "flex items-center gap-2 px-3 py-2 rounded-lg transition-all duration-300 w-full text-left",
            isActive 
              ? "!bg-primary !text-white shadow-lg" 
              : "text-gray-800 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-800"
          ]}
          data-active={isActive}
          onclick={`window.location.href='${node.url}'`}
        >
          <span>{node.icon}</span>
          <span>{node.name}</span>
          {isActive && (
            <span class="ml-auto text-xs bg-white/20 px-2 py-0.5 rounded-full">当前</span>
          )}
        </button>
      );
    })}
  </div>
</div>

<style is:global>
  [data-active="true"] {
    background-color: var(--primary) !important;
    color: white !important;
    box-shadow: 0 0 15px rgba(var(--primary-rgb), 0.4) !important;
    animation: nodeGlow 2s ease-in-out infinite !important;
  }
  
  @keyframes nodeGlow {
    0%, 100% {
      box-shadow: 0 0 8px rgba(var(--primary-rgb), 0.3), 0 0 15px rgba(var(--primary-rgb), 0.2);
    }
    50% {
      box-shadow: 0 0 15px rgba(var(--primary-rgb), 0.5), 0 0 25px rgba(var(--primary-rgb), 0.3);
    }
  }
</style>

<script>
  // 客户端双重保险：强制应用当前节点样式
  document.addEventListener('DOMContentLoaded', () => {
    const currentHost = window.location.hostname;
    document.querySelectorAll('button[data-active]').forEach(button => {
      const nodeUrl = new URL(button.getAttribute('onclick').split("'")[1]);
      if (nodeUrl.hostname === currentHost) {
        button.setAttribute('data-active', 'true');
        button.classList.add('!bg-primary', '!text-white', 'shadow-lg');
      }
    });
  });
</script>
