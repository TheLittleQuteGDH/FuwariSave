---
// 纯静态构建，零运行时开销
let currentNode = import.meta.env.SITE_NODE_NAME;

if (!currentNode) {
  if (import.meta.env.CF_PAGES) {
    currentNode = 'Cloudflare Pages';
  } else if (import.meta.env.NETLIFY) {
    currentNode = 'Netlify';
  } else if (import.meta.env.VERCEL) {
    currentNode = 'Vercel';
  } else if (import.meta.env.DEV) {
    currentNode = '本地开发';
  } else {
    currentNode = 'EdgeOne Pages';
  }
}
---

<p class="text-center text-sm text-gray-500 dark:text-gray-400 mt-2">
  当前节点是：
  <span class="font-semibold text-orange-500 dark:text-orange-400">{currentNode}</span>
</p>
