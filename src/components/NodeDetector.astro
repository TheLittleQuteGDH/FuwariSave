---
const nodes = [
  { name: "Cloudflare", url: "https://blog.thelittlequtegdh.fun", icon: "☁️" },
  { name: "EdgeOne", url: "https://edgeone.thelittlequtegdh.fun", icon: "🌐" },
  { name: "Netlify", url: "https://netlify.thelittlequtegdh.fun", icon: "🔷" },
  { name: "Vercel", url: "https://vercel.thelittlequtegdh.fun", icon: "▲" }
];

const currentHost = Astro.url.hostname;
---

<div class="card p-4">
  <!-- 标题栏 和 分类标签样式完全一致 -->
  <div class="flex items-center gap-2 mb-3">
    <div class="w-1.5 h-6 bg-primary rounded-full"></div>
    <span class="font-semibold text-xl text-gray-700 dark:text-gray-100">节点</span>
  </div>

  <div class="flex flex-col gap-2">
    {nodes.map((node) => {
      const nodeHost = new URL(node.url).hostname;
      const isActive = nodeHost === currentHost;
      return (
        <button
          type="button"
          data-active={isActive}
          class:list={[
            "flex items-center gap-2 px-3 py-2 rounded-lg w-full text-left transition-all duration-300",
            // 普通态：深浅模式文字+hover 完美适配主题
            "text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800/60",
            // 当前激活节点：点亮主色背景白字
            isActive && "!bg-primary !text-white shadow-md"
          ]}
          onclick={`window.location.href='${node.url}'`}
        >
          <span>{node.icon}</span>
          <span>{node.name}</span>
          {isActive && (
            <span class="ml-auto text-xs bg-white/20 px-2 py-0.5 rounded-full">当前</span>
          )}
        </button>
      );
    })}
  </div>
</div>

<style is:global>
  /* 当前节点 点燃发光效果 */
  [data-active="true"] {
    box-shadow: 0 0 12px rgba(var(--primary-rgb), 0.35) !important;
    animation: nodeGlow 2s ease-in-out infinite;
  }

  @keyframes nodeGlow {
    0%, 100% {
      box-shadow: 0 0 6px rgba(var(--primary-rgb), 0.25),
                  0 0 12px rgba(var(--primary-rgb), 0.15);
    }
    50% {
      box-shadow: 0 0 12px rgba(var(--primary-rgb), 0.45),
                  0 0 20px rgba(var(--primary-rgb), 0.25);
    }
  }
</style>

<script>
  // 客户端二次校准，保证一定点亮
  document.addEventListener('DOMContentLoaded', () => {
    const curHost = window.location.hostname;
    document.querySelectorAll('button[data-active]').forEach(btn => {
      const link = btn.getAttribute('onclick').split("'")[1];
      const host = new URL(link).hostname;
      if (host === curHost) {
        btn.dataset.active = "true";
        btn.classList.add('!bg-primary','!text-white','shadow-md');
      }
    });
  });
</script>
