---
// 🔥 不需要 prerender = false！纯静态构建
// 🔥 构建时直接获取环境变量，永久写入HTML

// 优先使用你自定义的节点名称
let currentNode = import.meta.env.SITE_NODE_NAME;

// 如果没有设置自定义名称，自动检测构建平台
if (!currentNode) {
  if (import.meta.env.CF_PAGES) {
    currentNode = 'Cloudflare Pages';
  } else if (import.meta.env.NETLIFY) {
    currentNode = 'Netlify';
  } else if (import.meta.env.VERCEL) {
    currentNode = 'Vercel';
  } else if (import.meta.env.DEV) {
    currentNode = '本地开发';
  } else {
    // EdgeOne Pages没有内置环境变量，必须手动设置
    currentNode = 'EdgeOne Pages';
  }
}

// 节点颜色配置
const nodeColors: Record<string, string> = {
  'Cloudflare Pages': '#F38020',
  'EdgeOne Pages': '#00A4FF',
  'Netlify': '#00C7B7',
  'Vercel': '#000000',
  '本地开发': '#6B7280',
  '未知节点': '#EF4444'
};

const nodeColor = nodeColors[currentNode] || nodeColors['未知节点'];
---

<span class="node-detector">
  当前节点是：<strong style="color: {nodeColor}">{currentNode}</strong>
</span>

<style>
.node-detector {
  font-size: 0.875rem;
  color: var(--text-secondary);
  margin-top: 0.5rem;
}
</style>
