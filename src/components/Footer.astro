---
import { siteConfig } from '@/config'

const currentYear = new Date().getFullYear()
const deployPlatform = import.meta.env.PUBLIC_DEPLOY_PLATFORM || "未知节点"
---

<footer class="mt-8 flex flex-col items-center justify-center gap-4 py-8 text-center text-sm">
  <p class="text-gray-500 dark:text-gray-400">
    当前节点：{deployPlatform}
  </p>
  <p class="text-gray-500 dark:text-gray-400">
    &copy; {currentYear} {siteConfig.author}. All rights reserved.
  </p>
  <p class="text-gray-400 dark:text-gray-500">
    Powered by <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a>
    & <a href="https://github.com/saicaca/fuwari" target="_blank" rel="noopener noreferrer">Fuwari</a>
  </p>
</footer>
