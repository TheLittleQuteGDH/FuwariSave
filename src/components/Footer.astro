---
import { profileConfig } from "../config";
import { url } from "../utils/url-utils";
const currentYear = new Date().getFullYear();

// 静态站点只能用构建时注入的变量
const deployNode = import.meta.env.PUBLIC_DEPLOY_NODE || "本地开发";
---

<footer class="mt-auto flex flex-col items-center py-8 text-center text-sm text-gray-500 dark:text-gray-400">
  <div class="flex items-center gap-2">
    <span>&copy; {currentYear} {profileConfig.name}</span>
    <span>·</span>
    <a href="https://github.com/saicaca/fuwari" target="_blank" rel="noopener noreferrer">Fuwari</a>
  </div>
  
  <!-- 节点显示 -->
  <div class="mt-2 flex items-center gap-1.5">
    <span class="inline-block w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
    <span>当前节点：<span class="font-medium text-primary">{deployNode}</span></span>
  </div>
</footer>
