---
import { Icon } from "astro-icon/components";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";

// 支持自定义文案与跳转地址，默认和截图完全一致
interface Props {
  title?: string;
  description?: string;
  sponsorUrl?: string;
}

const { 
  title = "支持与分享", 
  description = "如果这篇文章对你有帮助，欢迎分享给更多人或赞助支持！",
  sponsorUrl = "/sponsor/"
} = Astro.props;
---

<div class="w-full rounded-[var(--radius-large)] overflow-hidden bg-neutral-100/80 dark:bg-neutral-800/30 px-6 py-5">
  <div class="flex flex-col sm:flex-row w-full items-center justify-between gap-4">
    <!-- 左侧：爱心图标+文字区域 -->
    <div class="flex items-center gap-4 w-full sm:w-auto">
      <div class="w-12 h-12 rounded-lg bg-blue-500 flex items-center justify-center flex-shrink-0">
        <Icon name="fa6-solid:heart" class="text-white text-xl" />
      </div>
      <div class="flex flex-col">
        <h3 class="text-2xl font-bold text-neutral-900 dark:text-neutral-100">{title}</h3>
        <p class="text-base text-neutral-500 dark:text-neutral-400 mt-0.5">{description}</p>
      </div>
    </div>

    <!-- 右侧：按钮组 -->
    <div class="flex items-center gap-4 w-full sm:w-auto justify-end flex-shrink-0">
      <!-- 分享按钮 -->
      <button 
        id="share-button"
        class="flex items-center gap-2 px-6 py-3 rounded-[var(--radius-large)] bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 font-medium transition-all duration-300 hover:bg-blue-200 dark:hover:bg-blue-800/40"
      >
        <Icon name="fa6-solid:share-nodes" class="text-lg" />
        <span>分享</span>
      </button>

      <!-- 赞助按钮 -->
      <a 
        href={sponsorUrl}
        class="flex items-center gap-2 px-8 py-3 rounded-[var(--radius-large)] bg-blue-500 text-white font-medium transition-all duration-300 hover:bg-blue-600 hover:scale-[1.02] active:scale-[0.98]"
      >
        <span>{i18n(I18nKey.sponsor)}</span>
        <Icon name="fa6-solid:arrow-right" class="text-lg" />
      </a>
    </div>
  </div>
</div>

<!-- 分享功能客户端脚本，兼容原生分享+降级复制链接 -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const shareButton = document.getElementById('share-button');
    if (!shareButton) return;

    const pageTitle = document.title;
    const pageUrl = window.location.href;
    const pageDescription = document.querySelector('meta[name="description"]')?.getAttribute('content') || '';

    shareButton.addEventListener('click', async () => {
      // 优先调用浏览器原生分享API（适配移动端/现代浏览器）
      if (navigator.share) {
        try {
          await navigator.share({
            title: pageTitle,
            text: pageDescription,
            url: pageUrl
          });
          return;
        } catch (err) {
          if (err instanceof Error && err.name !== 'AbortError') {
            console.error('分享失败:', err);
          }
        }
      }

      // 不支持原生分享则自动复制链接到剪贴板
      try {
        await navigator.clipboard.writeText(pageUrl);
        alert('链接已复制到剪贴板，快去分享吧~');
      } catch (err) {
        console.error('复制链接失败:', err);
        // 极致降级兼容
        const input = document.createElement('input');
        input.value = pageUrl;
        document.body.appendChild(input);
        input.select();
        document.execCommand('copy');
        document.body.removeChild(input);
        alert('链接已复制到剪贴板，快去分享吧~');
      }
    });
  });
</script>
