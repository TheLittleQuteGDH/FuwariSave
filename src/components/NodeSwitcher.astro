---
const nodes = [
  { name: "EdgeOne", url: "https://edgeone.thelittlequtegdh.fun", icon: "🌐" },
  { name: "Cloudflare", url: "https://blog.thelittlequtegdh.fun", icon: "☁️" },
  { name: "Vercel", url: "https://vercel.thelittlequtegdh.fun", icon: "▲" }
];

// 获取当前域名
const currentUrl = new URL(Astro.url);
const currentHost = currentUrl.host;
---

<div class="card p-4">
  <div class="flex items-center gap-2 mb-3">
    <span class="i-carbon-network-3 text-lg"></span>
    <span class="font-semibold">节点</span>
  </div>
  
  <div class="flex flex-col gap-2">
    {nodes.map((node) => {
      const nodeHost = new URL(node.url).host;
      const isActive = nodeHost === currentHost;
      
      return (
        <a 
          href={node.url}
          class:list={[
            "flex items-center gap-2 px-3 py-2 rounded-lg transition-all duration-300",
            isActive 
              ? "bg-primary text-white shadow-md" 
              : "hover:bg-gray-100 dark:hover:bg-gray-800"
          ]}
          data-node={node.name}
        >
          <span>{node.icon}</span>
          <span>{node.name}</span>
          {isActive && (
            <span class="ml-auto text-xs bg-white/20 px-2 py-0.5 rounded-full">当前</span>
          )}
        </a>
      );
    })}
  </div>
</div>

<script>
  // 页面加载时检查并应用节点切换
  document.addEventListener('DOMContentLoaded', () => {
    const savedNode = localStorage.getItem('preferred-node');
    if (savedNode) {
      const nodeLinks = document.querySelectorAll('[data-node]');
      nodeLinks.forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const targetUrl = link.getAttribute('href');
          localStorage.setItem('preferred-node', link.dataset.node);
          window.location.href = targetUrl;
        });
      });
    }
  });
</script>
