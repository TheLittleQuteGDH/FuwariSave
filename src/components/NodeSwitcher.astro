---
interface Props {
    class?: string;
}

const className = Astro.props.class || "";
---

<div id="node-switcher" class:list={["flex flex-wrap gap-2", className]}>
    <button class="node-btn active" data-node="https://blog.thelIttlequtegdh.fun">Cloudflare</button>
    <button class="node-btn" data-node="https://edgeone.theLittleQuteGDH.fun">EdgeOne</button>
    <button class="node-btn" data-node="https://vercel.thelittlequtegdh.fun">Vercel</button>
</div>

<script is:inline>
document.addEventListener('DOMContentLoaded', () => {
    const switcher = document.getElementById('node-switcher');
    if (!switcher) return;
    
    const buttons = switcher.querySelectorAll('.node-btn');
    const currentHost = window.location.origin;
    const savedNode = localStorage.getItem('preferred-node');
    
    // 自动高亮当前节点
    buttons.forEach(btn => {
        const nodeUrl = btn.dataset.node;
        if (nodeUrl === currentHost || (savedNode && nodeUrl === savedNode)) {
            buttons.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
        }
        
        // 点击切换（保持当前页面路径）
        btn.addEventListener('click', () => {
            const targetNode = btn.dataset.node;
            if (targetNode === currentHost) return;
            
            localStorage.setItem('preferred-node', targetNode);
            window.location.href = targetNode + window.location.pathname + window.location.search;
        });
    });
});
</script>

<style is:global>
/* 100% 匹配Fuwari主题标签按钮样式 */
.node-btn {
    @apply px-2.5 py-1 text-sm rounded-md transition-all duration-200 
           bg-black/5 dark:bg-white/10 cursor-pointer;
}

.node-btn:hover {
    background-color: rgba(var(--primary-rgb), 0.1);
    color: var(--primary);
}

.node-btn.active {
    background-color: rgba(var(--primary-rgb), 0.15);
    color: var(--primary);
    font-weight: 500;
}
</style>
