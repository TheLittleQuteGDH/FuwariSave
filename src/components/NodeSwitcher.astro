---
import { Icon } from "astro-icon/components";

interface Props {
    class?: string;
}

const className = Astro.props.class || "";
---

<div class:list={["flex items-center gap-2 text-neutral-500 dark:text-neutral-400", className]}>
    <div class="meta-icon">
        <Icon name="material-symbols:cloud-outline-rounded" class="text-xl"></Icon>
    </div>
    <span class="text-50 text-sm font-medium mr-1">节点:</span>
    <div id="node-switcher" class="flex flex-wrap gap-1.5">
        <button class="node-btn active" data-node="https://blog.thelIttlequtegdh.fun">Cloudflare</button>
        <button class="node-btn" data-node="https://edgeone.theLittleQuteGDH.fun">EdgeOne</button>
        <button class="node-btn" data-node="https://vercel.thelittlequtegdh.fun">Vercel</button>
    </div>
</div>

<script is:inline>
// 节点切换逻辑
document.addEventListener('DOMContentLoaded', () => {
    const switcher = document.getElementById('node-switcher');
    if (!switcher) return;
    
    const buttons = switcher.querySelectorAll('.node-btn');
    const currentHost = window.location.origin;
    
    // 从localStorage读取保存的节点
    const savedNode = localStorage.getItem('preferred-node');
    
    // 设置当前激活的节点
    buttons.forEach(btn => {
        const nodeUrl = btn.dataset.node;
        if (nodeUrl === currentHost || (savedNode && nodeUrl === savedNode)) {
            buttons.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
        }
        
        // 点击切换节点
        btn.addEventListener('click', () => {
            const targetNode = btn.dataset.node;
            if (targetNode === currentHost) return;
            
            // 保存用户选择
            localStorage.setItem('preferred-node', targetNode);
            
            // 构建目标URL（保持当前路径）
            const targetUrl = targetNode + window.location.pathname + window.location.search;
            
            // 切换页面
            window.location.href = targetUrl;
        });
    });
    
    // 页面加载时自动跳转到保存的节点（如果不是当前节点）
    if (savedNode && savedNode !== currentHost) {
        // 可选：自动跳转
        // window.location.href = savedNode + window.location.pathname + window.location.search;
    }
});
</script>

<style is:global>
.node-btn {
    @apply px-2 py-0.5 text-xs rounded-md transition-all duration-200 
           bg-black/5 dark:bg-white/10 
           hover:bg-[var(--primary)]/10 dark:hover:bg-[var(--primary)]/20
           hover:text-[var(--primary)];
}

.node-btn.active {
    @apply bg-[var(--primary)]/15 dark:bg-[var(--primary)]/25 
           text-[var(--primary)] font-medium;
}

.meta-icon {
    @apply transition h-6 w-6 rounded-md bg-black/5 dark:bg-white/10 
           text-black/50 dark:text-white/50 flex items-center justify-center mr-2;
}
</style>
